@using CarRental.Utilities;
@{
    // Xác định controller và action hiện tại để set class 'active' cho menu
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý xe - Chủ xe</title>

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/admin/assets/css/bootstrap.css">
    <link rel="stylesheet" href="~/admin/assets/vendors/iconly/bold.css">
    <link rel="stylesheet" href="~/admin/assets/vendors/perfect-scrollbar/perfect-scrollbar.css">
    <link rel="stylesheet" href="~/admin/assets/vendors/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="~/admin/assets/css/app.css">
    <link rel="shortcut icon" href="~/admin/assets/images/favicon.svg" type="image/x-icon">
    <script src="~/admin/assets/vendors/jquery/jquery.min.js"></script>
</head>

<body>
    <div id="app">
        <div id="sidebar" class="active">
            <div class="sidebar-wrapper active">
                <div class="sidebar-header">
                    <div class="d-flex justify-content-between row">
                        <div class="logo ">
                            <a href="/CarOwner/Home/Index" style="text-decoration: none; color: inherit; display: flex; align-items: center;">
                                <img src="~/admin/assets/images/faces/1.jpg" alt="profile" class="rounded-circle col-auto" />
                                <h6 class="col">@Function._UserName</h6>
                            </a>
                        </div>
                        <div class="toggler">
                            <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                        </div>
                    </div>
                </div>
                <div class="sidebar-menu">
                    <ul class="menu">
                        <li class="sidebar-title">Menu Chủ xe</li>

                        <li class="sidebar-item @(currentController == "Home" ? "active" : "")">
                            <a asp-controller="Home" asp-action="Index" asp-area="CarOwner" class='sidebar-link'>
                                <i class="bi bi-grid-fill me-2"></i>
                                <span>Trang chủ</span>
                            </a>
                        </li>

                        <li class="sidebar-item @((currentController == "Cars" && currentAction == "Index") ? "active" : "")">
                            <a asp-controller="Cars" asp-action="Index" asp-area="CarOwner" class='sidebar-link'>
                                <i class="bi bi-speedometer2 me-2"></i>
                                <span>Quản lý xe</span>
                            </a>
                        </li>

                        <li class="sidebar-item @((currentController == "Cars" && currentAction == "Create") ? "active" : "")">
                            <a asp-controller="Cars" asp-action="Create" asp-area="CarOwner" class='sidebar-link'>
                                <i class="bi bi-plus-circle me-2"></i>
                                <span>Thêm xe mới</span>
                            </a>
                        </li>

                        <li class="sidebar-item @(currentController == "Orders" ? "active" : "")">
                            <a asp-controller="Orders" asp-action="Index" asp-area="CarOwner" class='sidebar-link'>
                                <i class="bi bi-receipt me-2"></i>
                                <span>Đơn đặt xe</span>
                            </a>
                        </li>

                        <li class="sidebar-item">
                            <a asp-controller="Home" asp-action="Logout" asp-area="CarOwner" class='sidebar-link'>
                                <i class="bi bi-box-arrow-right me-2"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
            </div>
        </div>
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
    <script src="~/admin/assets/vendors/perfect-scrollbar/perfect-scrollbar.min.js"></script>
    <script src="~/admin/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/admin/assets/vendors/apexcharts/apexcharts.js"></script>
    <script src="~/admin/assets/js/pages/dashboard.js"></script>
    <script src="~/admin/assets/js/main.js"></script>
</body>

</html>

