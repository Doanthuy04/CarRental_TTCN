@model CarRental.Models.Car
@using CarRental.Utilities
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thêm xe mới";
    Layout = "~/Areas/CarOwner/Views/Shared/_Layout.cshtml";
}

<div id="main">
    <header class="mb-3">
        <a href="#" class="burger-btn d-block d-xl-none">
            <i class="bi bi-justify fs-3"></i>
        </a>
    </header>

    <style>
        .page-header-modern {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 2rem;
            border-radius: 15px;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
        }

        .page-header-modern h3 {
            color: white;
            font-weight: 600;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header-modern h3 i {
            font-size: 1.5rem;
        }

        .breadcrumb-modern {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            margin: 0;
        }

        .breadcrumb-modern .breadcrumb-item a {
            color: rgba(255, 255, 255, 0.9);
            text-decoration: none;
        }

        .breadcrumb-modern .breadcrumb-item.active {
            color: white;
            font-weight: 500;
        }

        .form-card-modern {
            background: white;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            border: none;
        }

        .form-card-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 1.5rem;
            color: white;
        }

        .form-card-header h4 {
            margin: 0;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-card-body {
            padding: 2rem;
        }

        .form-group-modern {
            margin-bottom: 1.5rem;
        }

        .form-group-modern label {
            font-weight: 600;
            color: #333;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .form-group-modern label i {
            color: #667eea;
        }

        .form-control-modern {
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .form-control-modern:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
            outline: none;
        }

        .form-select.form-control-modern {
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 0.75rem center;
            background-size: 16px 12px;
        }

        .form-select.form-control-modern:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.15);
            outline: none;
        }

        .btn-modern-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }

        .btn-modern-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
            color: white;
        }

        .btn-modern-secondary {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(245, 87, 108, 0.3);
        }

        .btn-modern-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245, 87, 108, 0.4);
            color: white;
        }

        .btn-image-selector {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            border: none;
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(79, 172, 254, 0.3);
        }

        .btn-image-selector:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 172, 254, 0.4);
            color: white;
        }

        .form-check-modern {
            padding: 0;
            background: transparent;
            border-radius: 0;
            border: none;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            height: 100%;
            min-height: 3.5rem;
        }

        .form-check-modern:hover {
            border-color: transparent;
            background: transparent;
        }

        .form-check-modern .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            cursor: pointer;
            margin-top: 0;
            margin-right: 0.5rem;
        }

        .form-check-modern .form-check-label {
            margin-left: 0;
            cursor: pointer;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .checkbox-wrapper {
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 10px;
            border: 2px solid #e9ecef;
            transition: all 0.3s ease;
            height: 100%;
            display: flex;
            align-items: center;
            min-height: 3.5rem;
        }

        .checkbox-wrapper:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }

        .alert-modern {
            border-radius: 10px;
            border: none;
            padding: 1rem 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        .input-group-modern {
            display: flex;
            gap: 0.5rem;
        }

        .input-group-modern .form-control {
            flex: 1;
        }

        @@media (max-width: 768px) {
            .page-header-modern {
                padding: 1.5rem;
            }

            .form-card-body {
                padding: 1.5rem;
            }

            .btn-modern-primary,
            .btn-modern-secondary {
                width: 100%;
                margin-bottom: 0.5rem;
            }
        }
    </style>

    <div class="page-heading">
        <div class="page-header-modern">
            <div class="row align-items-center">
                <div class="col-12 col-md-6 order-md-1 order-last">
                    <h3>
                        <i class="bi bi-plus-circle-fill"></i>
                        Thêm xe mới
                    </h3>
                </div>
                <div class="col-12 col-md-6 order-md-2 order-first">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-modern">
                            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="CarOwner">Trang chủ</a></li>
                            <li class="breadcrumb-item"><a asp-action="Index">Quản lý xe</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Thêm xe mới</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <section class="section">
            <div class="card form-card-modern">
                <div class="form-card-header">
                    <h4>
                        <i class="bi bi-car-front"></i>
                        Thông tin xe
                    </h4>
                </div>
                <div class="form-card-body">
                    @if (!string.IsNullOrEmpty(Function._Message))
                    {
                        <div class="alert alert-info alert-modern">@Function._Message</div>
                        Function._Message = string.Empty;
                    }

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="CarName">
                                        <i class="bi bi-tag-fill"></i>
                                        Tên xe <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="CarName" type="text" class="form-control form-control-modern" placeholder="Nhập tên xe" required>
                                    <span asp-validation-for="CarName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="TypeId">
                                        <i class="bi bi-grid-3x3-gap-fill"></i>
                                        Hạng xe <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="TypeId" asp-items="ViewBag.CarTypes" class="form-select form-control-modern" required>
                                    </select>
                                    <span asp-validation-for="TypeId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="LicensePlate">
                                        <i class="bi bi-123"></i>
                                        Biển số <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="LicensePlate" type="text" class="form-control form-control-modern" placeholder="Nhập biển số xe" required>
                                    <span asp-validation-for="LicensePlate" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="Seat">
                                        <i class="bi bi-people-fill"></i>
                                        Số chỗ ngồi
                                    </label>
                                    <input asp-for="Seat" type="number" class="form-control form-control-modern" placeholder="Nhập số chỗ ngồi">
                                    <span asp-validation-for="Seat" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group-modern">
                                    <label asp-for="Color">
                                        <i class="bi bi-palette-fill"></i>
                                        Màu xe
                                    </label>
                                    <input asp-for="Color" type="text" class="form-control form-control-modern" placeholder="Nhập màu xe">
                                    <span asp-validation-for="Color" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group-modern">
                                    <label asp-for="Model">
                                        <i class="bi bi-calendar-event"></i>
                                        Năm sản xuất
                                    </label>
                                    <input asp-for="Model" type="text" class="form-control form-control-modern" placeholder="Nhập năm sản xuất">
                                    <span asp-validation-for="Model" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group-modern">
                                    <label asp-for="CarBrand">
                                        <i class="bi bi-building"></i>
                                        Hãng xe
                                    </label>
                                    <input asp-for="CarBrand" type="text" class="form-control form-control-modern" placeholder="Nhập tên hãng xe">
                                    <span asp-validation-for="CarBrand" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="Price">
                                        <i class="bi bi-currency-dollar"></i>
                                        Giá thuê/ngày (VNĐ) <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Price" type="number" class="form-control form-control-modern" placeholder="Nhập giá thuê" required>
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="SalePrice">
                                        <i class="bi bi-tag-fill"></i>
                                        Giá giảm/ngày (VNĐ)
                                    </label>
                                    <input asp-for="SalePrice" type="number" class="form-control form-control-modern" placeholder="Nhập giá giảm (nếu có)">
                                    <span asp-validation-for="SalePrice" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Image">
                                <i class="bi bi-image-fill"></i>
                                Ảnh đại diện
                            </label>
                            <div class="input-group-modern">
                                <button class="btn btn-image-selector" type="button" onclick="openDialog()">
                                    <i class="bi bi-folder2-open"></i> Chọn ảnh
                                </button>
                                <input asp-for="Image" type="text" class="form-control form-control-modern" id="file_input" placeholder="Đường dẫn ảnh">
                            </div>
                            <span asp-validation-for="Image" class="text-danger"></span>
                            <small class="form-text text-muted">Bạn có thể chọn nhiều ảnh, cách nhau bằng dấu phẩy</small>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Descriptions">
                                <i class="bi bi-card-text"></i>
                                Mô tả ngắn
                            </label>
                            <textarea asp-for="Descriptions" class="form-control form-control-modern" rows="3" placeholder="Nhập mô tả ngắn về xe"></textarea>
                            <span asp-validation-for="Descriptions" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Details">
                                <i class="bi bi-file-text-fill"></i>
                                Chi tiết
                            </label>
                            <textarea asp-for="Details" class="form-control form-control-modern" rows="5" placeholder="Nhập thông tin chi tiết về xe"></textarea>
                            <span asp-validation-for="Details" class="text-danger"></span>
                        </div>

                        <div class="row align-items-end">
                            <div class="col-md-4">
                                <div class="form-group-modern">
                                    <label asp-for="Rate">
                                        <i class="bi bi-star-fill"></i>
                                        Đánh giá (sao)
                                    </label>
                                    <input asp-for="Rate" type="number" step="0.1" min="0" max="5" class="form-control form-control-modern" placeholder="0-5">
                                    <span asp-validation-for="Rate" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="checkbox-wrapper">
                                    <div class="form-check-modern">
                                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                                        <label asp-for="IsActive" class="form-check-label">
                                            <i class="bi bi-eye-fill"></i> Hiển thị trên hệ thống
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="checkbox-wrapper">
                                    <div class="form-check-modern">
                                        <input asp-for="IsSale" class="form-check-input" type="checkbox">
                                        <label asp-for="IsSale" class="form-check-label">
                                            <i class="bi bi-percent"></i> Đang giảm giá
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" id="filePaths" name="filePaths" value="" />

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-modern-primary">
                                <i class="bi bi-check-circle-fill"></i> Thêm xe
                            </button>
                            <a asp-action="Index" class="btn btn-modern-secondary">
                                <i class="bi bi-arrow-left-circle-fill"></i> Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/admin/lib/jqueryui/themes/themes/base/theme.css" />
    <link rel="stylesheet" href="~/admin/lib/jqueryui/themes/jquery-ui.css" />
    <link rel="stylesheet" href="~/admin/lib/elfinder/css/elfinder.full.css" />
    <link rel="stylesheet" href="~/admin/lib/elfinder/css/theme.min.css" />

    <script src="~/admin/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/admin/lib/jqueryui/jquery-ui.min.js"></script>
    <script src="~/admin/lib/elfinder/js/elfinder.min.js"></script>

    <script type="text/javascript">
        function openDialog() {
            var getFileCallback = function (files) {
                var inputElement = document.getElementById('file_input');
                var filePathsInput = document.getElementById('filePaths');
                var currentValue = inputElement.value;

                if (Array.isArray(files)) {
                    var urls = files.map(function (file) {
                        return file.url;
                    });

                    inputElement.value = currentValue
                        ? currentValue + ', ' + urls.join(', ')
                        : urls.join(', ');
                    
                    filePathsInput.value = urls.join(',');
                } else {
                    inputElement.value = files.url;
                    filePathsInput.value = files.url;
                }
            };

            var dialog = $('<div/>').dialogelfinder({
                baseUrl: "@Url.Content("~/admin/lib/elFinder/")",
                url: '/Admin/el-finder-file-system/connector',
                lang: 'vi',
                width: 840,
                height: 450,
                destroyOnClose: true,
                closeOnEditorCallback: true,
                getFileCallback: getFileCallback,
                commandsOptions: {
                    getfile: {
                        oncomplete: 'close',
                        folders: false,
                        multiple: true
                    }
                }
            }).dialogelfinder('instance');
            
            // Xử lý double-click để tự động chọn file và đóng dialog
            dialog.one('open', function() {
                var elfinder = dialog.elfinder('instance');
                if (elfinder) {
                    // Override command map để double-click vào file sẽ gọi getfile thay vì open
                    var originalOpen = elfinder.commandMap.open;
                    elfinder.commandMap.open = 'getfile';
                    
                    // Bind event dblclick để xử lý khi double-click
                    elfinder.bind('dblclick', function(e) {
                        var file = e.data.file;
                        if (file && file.mime && file.mime.indexOf('image/') === 0) {
                            // Gọi getfile command để chọn file
                            elfinder.exec('getfile', [file.hash]);
                        }
                    });
                    
                    // Restore original command map khi dialog đóng
                    dialog.on('close', function() {
                        if (originalOpen) {
                            elfinder.commandMap.open = originalOpen;
                        }
                    });
                }
            });
        }

    </script>
}

