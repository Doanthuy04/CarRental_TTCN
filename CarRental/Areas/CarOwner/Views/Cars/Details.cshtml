@model CarRental.Models.Car
@using CarRental.Utilities
@{
    ViewData["Title"] = "Chi tiết xe";
    Layout = "~/Areas/CarOwner/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header-modern {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }

    .page-header-modern h3 {
        color: white;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-header-modern h3 i {
        font-size: 1.5rem;
    }

    .breadcrumb-modern {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        margin: 0;
    }

    .breadcrumb-modern .breadcrumb-item a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
    }

    .breadcrumb-modern .breadcrumb-item.active {
        color: white;
        font-weight: 500;
    }

    .details-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        border: none;
    }

    .card-header-modern {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1.5rem;
        color: white;
    }

    .card-header-modern h4 {
        margin: 0;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-section {
        padding: 1.5rem;
        border-bottom: 1px solid #f0f0f0;
    }

    .info-section:last-child {
        border-bottom: none;
    }

    .info-item {
        padding: 0.75rem 0;
        display: flex;
        align-items: flex-start;
    }

    .info-label {
        font-weight: 600;
        color: #495057;
        min-width: 150px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-label i {
        color: #667eea;
    }

    .info-value {
        color: #212529;
        flex: 1;
    }

    .badge-modern {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .car-image-large {
        max-width: 100%;
        max-height: 400px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        object-fit: cover;
    }

    .review-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 1rem;
        margin-bottom: 1rem;
        border-left: 4px solid #667eea;
        transition: all 0.3s ease;
    }

    .review-card:hover {
        background: #f0f4ff;
        transform: translateX(5px);
    }

    .star-rating {
        color: #ffc107;
    }

    .btn-modern-edit {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        border: none;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(17, 153, 142, 0.3);
    }

    .btn-modern-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(17, 153, 142, 0.4);
        color: white;
    }

    .btn-modern-back {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(245, 87, 108, 0.3);
    }

    .btn-modern-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 87, 108, 0.4);
        color: white;
    }

    .alert-modern {
        border-radius: 10px;
        border: none;
        padding: 1rem 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #667eea;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    @@media (max-width: 768px) {
        .page-header-modern {
            padding: 1.5rem;
        }

        .info-item {
            flex-direction: column;
        }

        .info-label {
            min-width: auto;
            margin-bottom: 0.5rem;
        }
    }
</style>

<div id="main">
    <header class="mb-3">
        <a href="#" class="burger-btn d-block d-xl-none">
            <i class="bi bi-justify fs-3"></i>
        </a>
    </header>

    <div class="page-heading">
        <div class="page-header-modern">
            <div class="row align-items-center">
                <div class="col-12 col-md-6 order-md-1 order-last">
                    <h3>
                        <i class="bi bi-car-front-fill"></i>
                        Chi tiết xe
                    </h3>
                </div>
                <div class="col-12 col-md-6 order-md-2 order-first">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-modern">
                            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="CarOwner">Trang chủ</a></li>
                            <li class="breadcrumb-item"><a asp-action="Index">Quản lý xe</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Chi tiết xe</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <section class="section">
            <div class="card details-card">
                <div class="card-header-modern">
                    <h4>
                        <i class="bi bi-info-circle-fill"></i>
                        Thông tin xe: @Model.CarName
                    </h4>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(Function._Message))
                    {
                        <div class="alert alert-info alert-modern m-3">@Function._Message</div>
                        Function._Message = string.Empty;
                    }

                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <div class="info-section text-center">
                            <img src="@Model.Image" alt="@Model.CarName" class="car-image-large" />
                        </div>
                    }

                    <div class="info-section">
                        <h5 class="section-title">
                            <i class="bi bi-clipboard-data"></i>
                            Thông tin cơ bản
                        </h5>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-tag-fill"></i> Tên xe:
                                    </span>
                                    <span class="info-value fw-bold">@Model.CarName</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-grid-3x3-gap-fill"></i> Hạng xe:
                                    </span>
                                    <span class="info-value">@(Model.Type?.CarTypeName ?? "N/A")</span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-123"></i> Biển số:
                                    </span>
                                    <span class="info-value">@Model.LicensePlate</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-people-fill"></i> Số chỗ ngồi:
                                    </span>
                                    <span class="info-value">@(Model.Seat?.ToString() ?? "N/A")</span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-palette-fill"></i> Màu xe:
                                    </span>
                                    <span class="info-value">@(Model.Color ?? "N/A")</span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-calendar-event"></i> Năm sản xuất:
                                    </span>
                                    <span class="info-value">@(Model.Model?.ToString() ?? "N/A")</span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-building"></i> Hãng xe:
                                    </span>
                                    <span class="info-value">@(Model.CarBrand ?? "N/A")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="info-section">
                        <h5 class="section-title">
                            <i class="bi bi-currency-dollar"></i>
                            Thông tin giá
                        </h5>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-cash-stack"></i> Giá thuê/ngày:
                                    </span>
                                    <span class="info-value text-primary fw-bold fs-5">@string.Format("{0:N0}", Model.Price) ₫</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-tag-fill"></i> Giá giảm/ngày:
                                    </span>
                                    <span class="info-value text-success fw-bold fs-5">@(Model.SalePrice.HasValue ? string.Format("{0:N0}", Model.SalePrice) + " ₫" : "N/A")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="info-section">
                        <h5 class="section-title">
                            <i class="bi bi-star-fill"></i>
                            Đánh giá & Trạng thái
                        </h5>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-star-fill"></i> Đánh giá:
                                    </span>
                                    <span class="info-value">
                                        @if (Model.Rate.HasValue)
                                        {
                                            <div class="star-rating">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    if (i < Model.Rate.Value)
                                                    {
                                                        <i class="bi bi-star-fill"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-star"></i>
                                                    }
                                                }
                                            </div>
                                            <span class="ms-2">(@Model.Rate.Value.ToString("F1")/5)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có đánh giá</span>
                                        }
                                    </span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-toggle-on"></i> Trạng thái:
                                    </span>
                                    <span class="info-value">
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge badge-modern bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-modern bg-danger">Tạm dừng</span>
                                        }
                                        @if (Model.IsSale)
                                        {
                                            <span class="badge badge-modern bg-warning ms-2">Đang giảm giá</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Descriptions))
                    {
                        <div class="info-section">
                            <h5 class="section-title">
                                <i class="bi bi-card-text"></i>
                                Mô tả ngắn
                            </h5>
                            <div class="info-item">
                                <span class="info-value">@Model.Descriptions</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Details))
                    {
                        <div class="info-section">
                            <h5 class="section-title">
                                <i class="bi bi-file-text-fill"></i>
                                Chi tiết
                            </h5>
                            <div class="info-item">
                                <span class="info-value">@Html.Raw(Model.Details)</span>
                            </div>
                        </div>
                    }

                    @if (Model.CarReviews != null && Model.CarReviews.Any())
                    {
                        <div class="info-section">
                            <h5 class="section-title">
                                <i class="bi bi-chat-left-text-fill"></i>
                                Đánh giá từ khách hàng (@Model.CarReviews.Count)
                            </h5>
                            @foreach (var review in Model.CarReviews.Take(5))
                            {
                                <div class="review-card">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <strong class="d-flex align-items-center gap-2">
                                            <i class="bi bi-person-circle"></i>
                                            @(review.Name ?? "Khách hàng")
                                        </strong>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i>
                                            @review.CreatedDate?.ToString("dd/MM/yyyy")
                                        </small>
                                    </div>
                                    @if (review.Star.HasValue)
                                    {
                                        <div class="star-rating mb-2">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                if (i < review.Star.Value)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star"></i>
                                                }
                                            }
                                        </div>
                                    }
                                    <p class="mb-0">@(review.Detail ?? "Không có nhận xét")</p>
                                </div>
                            }
                        </div>
                    }

                    <div class="info-section">
                        <div class="d-flex gap-3">
                            <a asp-action="Edit" asp-route-id="@Model.CarId" class="btn btn-modern-edit">
                                <i class="bi bi-pencil-fill"></i> Sửa
                            </a>
                            <a asp-action="Index" class="btn btn-modern-back">
                                <i class="bi bi-arrow-left-circle-fill"></i> Quay lại
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
