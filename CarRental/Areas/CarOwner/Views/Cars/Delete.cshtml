@model CarRental.Models.Car
@using CarRental.Utilities
@{
    ViewData["Title"] = "Xóa xe";
    Layout = "~/Areas/CarOwner/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header-modern {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(245, 87, 108, 0.3);
    }

    .page-header-modern h3 {
        color: white;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-header-modern h3 i {
        font-size: 1.5rem;
    }

    .breadcrumb-modern {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        margin: 0;
    }

    .breadcrumb-modern .breadcrumb-item a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
    }

    .breadcrumb-modern .breadcrumb-item.active {
        color: white;
        font-weight: 500;
    }

    .delete-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        border: none;
    }

    .card-header-modern {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 1.5rem;
        color: white;
    }

    .card-header-modern h4 {
        margin: 0;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .warning-banner {
        background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
        border: none;
        border-left: 5px solid #f5576c;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(245, 87, 108, 0.2);
    }

    .warning-banner i {
        font-size: 2rem;
        color: #f5576c;
        margin-right: 1rem;
    }

    .warning-banner strong {
        color: #d63384;
        font-size: 1.1rem;
    }

    .car-info-section {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .info-item {
        padding: 0.75rem 0;
        display: flex;
        align-items: flex-start;
    }

    .info-label {
        font-weight: 600;
        color: #495057;
        min-width: 150px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-label i {
        color: #f5576c;
    }

    .info-value {
        color: #212529;
        flex: 1;
        font-weight: 500;
    }

    .car-image-preview {
        max-width: 100%;
        max-height: 300px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        object-fit: cover;
        border: 3px solid #f5576c;
    }

    .btn-modern-delete {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(245, 87, 108, 0.3);
    }

    .btn-modern-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 87, 108, 0.4);
        color: white;
    }

    .btn-modern-cancel {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .btn-modern-cancel:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .alert-modern {
        border-radius: 10px;
        border: none;
        padding: 1rem 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 768px) {
        .page-header-modern {
            padding: 1.5rem;
        }

        .info-item {
            flex-direction: column;
        }

        .info-label {
            min-width: auto;
            margin-bottom: 0.5rem;
        }

        .car-info-section {
            padding: 1.5rem;
        }
    }
</style>

<div id="main">
    <header class="mb-3">
        <a href="#" class="burger-btn d-block d-xl-none">
            <i class="bi bi-justify fs-3"></i>
        </a>
    </header>

    <div class="page-heading">
        <div class="page-header-modern">
            <div class="row align-items-center">
                <div class="col-12 col-md-6 order-md-1 order-last">
                    <h3>
                        <i class="bi bi-trash-fill"></i>
                        Xóa xe
                    </h3>
                </div>
                <div class="col-12 col-md-6 order-md-2 order-first">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-modern">
                            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="CarOwner">Trang chủ</a></li>
                            <li class="breadcrumb-item"><a asp-action="Index">Quản lý xe</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Xóa xe</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>

        <section class="section">
            <div class="card delete-card">
                <div class="card-header-modern">
                    <h4>
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Xác nhận xóa xe
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Function._Message))
                    {
                        <div class="alert alert-info alert-modern">@Function._Message</div>
                        Function._Message = string.Empty;
                    }

                    <div class="warning-banner d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>
                            <strong>Cảnh báo!</strong>
                            <p class="mb-0 mt-1">Bạn có chắc chắn muốn xóa xe này không? Hành động này không thể hoàn tác!</p>
                        </div>
                    </div>

                    <div class="car-info-section">
                        <h5 class="mb-4 text-danger">
                            <i class="bi bi-car-front"></i>
                            Thông tin xe sẽ bị xóa
                        </h5>

                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <div class="text-center mb-4">
                                <img src="@Model.Image" alt="@Model.CarName" class="car-image-preview" />
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-tag-fill"></i> Tên xe:
                                    </span>
                                    <span class="info-value">@Model.CarName</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-grid-3x3-gap-fill"></i> Hạng xe:
                                    </span>
                                    <span class="info-value">@(Model.Type?.CarTypeName ?? "N/A")</span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-123"></i> Biển số:
                                    </span>
                                    <span class="info-value">@Model.LicensePlate</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-item">
                                    <span class="info-label">
                                        <i class="bi bi-currency-dollar"></i> Giá thuê/ngày:
                                    </span>
                                    <span class="info-value text-primary fw-bold">@string.Format("{0:N0}", Model.Price) ₫</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="CarId" />
                        <div class="d-flex gap-3 justify-content-center mt-4">
                            <button type="submit" class="btn btn-modern-delete">
                                <i class="bi bi-trash-fill"></i> Xác nhận xóa
                            </button>
                            <a asp-action="Index" class="btn btn-modern-cancel">
                                <i class="bi bi-x-circle-fill"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </div>
</div>


